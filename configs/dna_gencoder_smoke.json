{
  "dataset_dir": "datasets/DNACorpus",
  "output_dir": "outputs/dna_gencoder_smoke",
  "device": "auto",
  "seed": 42,
  "runs": [
    {
      "name": "smoke",
      "species": ["YeMi", "AgPh"],
      "seq_length": 128,
      "bottleneck_dim": 16,
      "epochs": 1,
      "batch_size": 8,
      "eval_batch_size": 8,
      "learning_rate": 0.001,
      "validation_ratio": 0.2,
      "max_bytes_per_source": 4096,
      "save_artifacts": true
    }
  ]
}
