{
  "model": {
    "implementation": "nugget",
    "variant": "dna_gpt0.1b_m",
    "vocab_size": 259,
    "seq_length": 1024,
    "pad_id": 257,
    "eos_id": 258,
    "nugget_backbone": "bart",
    "nugget_bart_config_path": "configs/hf/facebook_bart_base_config.json",
    "nugget_bart_d_model": 768,
    "nugget_bart_encoder_layers": 6,
    "nugget_bart_decoder_layers": 6,
    "nugget_bart_encoder_attention_heads": 12,
    "nugget_bart_decoder_attention_heads": 12,
    "nugget_bart_encoder_ffn_dim": 3072,
    "nugget_bart_decoder_ffn_dim": 3072,
    "nugget_bart_dropout": 0.1,
    "nugget_bart_attention_dropout": 0.1,
    "nugget_bart_activation_dropout": 0.1,
    "nugget_bart_max_position_embeddings": 1024,
    "nugget_t5_d_model": 512,
    "nugget_t5_d_ff": 2048,
    "nugget_t5_num_layers": 6,
    "nugget_t5_num_decoder_layers": 6,
    "nugget_t5_num_heads": 8,
    "nugget_t5_d_kv": 64,
    "nugget_t5_dropout_rate": 0.1,
    "nugget_ratio": 0.25,
    "nugget_scorer_layer": 3,
    "nugget_residual_start": 0,
    "nugget_residual_end": -1,      
    "nugget_value_ffn": true,
    "nugget_straight_through": true,
    "nugget_hidden_mode": "runtime_hidden",
    "nugget_hidden_storage_dtype": "runtime"
  },
  "data": {
    "dataset_dir": "datasets/DNACorpus",
    "species": [
      "HoSa"
    ],
    "nugget_tokenizer": "byte",
    "species_prefix_map": {},
    "train_ratio": 0.9,
    "val_ratio": 0.05,
    "test_ratio": 0.05,
    "max_train_bytes_per_species": null,
    "max_val_bytes_per_species": null,
    "max_test_bytes_per_species": null,
    "train_samples_per_epoch": 1024,
    "train_sampling_strategy": "proportional",
    "token_merge_size": 1,
    "token_merge_alphabet": "ACGTN",
    "compression_sample_bytes": 16384
  },
  "arithmetic": {
    "coding_mode": "model_symbol",
    "merge_size": 1
  },
  "train": {
    "seed": 42,
    "device": "auto",
    "dtype": "float16",
    "init_from": "scratch",
    "epochs": 1,
    "batch_size": 8,
    "eval_batch_size": 8,
    "learning_rate": 0.0003,
    "weight_decay": 0.01,
    "lr_scheduler": "none",
    "lr_warmup_steps": 0,
    "lr_min_ratio": 0.0,
    "grad_clip_norm": 1.0,
    "num_workers": 0,
    "prefetch_factor": 2,
    "persistent_workers": false,
    "pin_memory": true,
    "log_interval": 25,
    "eval_interval": 100
  },
  "output": {
    "run_name": "dna_nugget_quick",
    "output_dir": "outputs/dna_nugget_quick"
  }
}
